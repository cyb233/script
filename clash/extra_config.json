{
  "mode": "rule",
  "mixed-port": 7890,
  "allow-lan": false,
  "rule-providers": {
    "local-reject": {
      "type": "http",
      "behavior": "classical",
      "url": "https://shuvi.moe/script/clash/rulesets/local-reject.yaml",
      "interval": 86400,
      "path": "./rulesets/local-reject.yaml"
    },
    "local-proxies": {
      "type": "http",
      "behavior": "classical",
      "url": "https://shuvi.moe/script/clash/rulesets/local-proxies.yaml",
      "interval": 86400,
      "path": "./rulesets/local-proxies.yaml"
    },
    "local-tw": {
      "type": "http",
      "behavior": "classical",
      "url": "https://shuvi.moe/script/clash/rulesets/local-tw.yaml",
      "interval": 86400,
      "path": "./rulesets/local-tw.yaml"
    },
    "local-jp": {
      "type": "http",
      "behavior": "classical",
      "url": "https://shuvi.moe/script/clash/rulesets/local-jp.yaml",
      "interval": 86400,
      "path": "./rulesets/local-jp.yaml"
    },
    "local-direct": {
      "type": "http",
      "behavior": "classical",
      "url": "https://shuvi.moe/script/clash/rulesets/local-direct.yaml",
      "interval": 86400,
      "path": "./rulesets/local-direct.yaml"
    }
  },
  "rules": [
    "RULE-SET,local-reject,REJECT",
    "RULE-SET,local-proxies,Proxies",
    "RULE-SET,local-tw,TW",
    "RULE-SET,local-jp,JP",
    "RULE-SET,local-direct,DIRECT"
  ]
}
